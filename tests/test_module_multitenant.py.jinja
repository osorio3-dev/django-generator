def test_schema_middleware_resolves_tenant(settings):
    """Schema mode requires django-tenants. If not installed, skip."""
    pytest.importorskip("django_tenants", reason="schema isolation requires django-tenants package")

    from apps.tenants.middleware import TenantSchemaMiddleware

    settings.ALLOWED_HOSTS = ["*"]  # so test host is allowed

    rf = RequestFactory()
    from django.http import HttpResponse
    middleware = TenantSchemaMiddleware(lambda r: HttpResponse("ok"))
    req = rf.get("/", HTTP_HOST="acme.example.com")
    response = middleware(req)
    # No Tenant with schema_name='public' in test DB → middleware returns 404.
    assert response.status_code in (200, 404)
