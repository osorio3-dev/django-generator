def test_issue_and_redeem_token(user):
    from apps.accounts.autologin.models import AutoLoginToken, AutoLoginUsage
    from apps.accounts.autologin.views import issue_token

    token_record, plaintext = issue_token(user=user)
    assert AutoLoginToken.all_objects.filter(token_hash=token_record.token_hash).exists()

    client = Client()
    url = reverse("autologin", args=[plaintext])
    response = client.post(url)
    assert response.status_code == 302  # redirect after login
    assert response.url == "/"

    token_record.refresh_from_db()
    assert token_record.is_used

    usage = AutoLoginUsage.all_objects.filter(outcome="success").first()
    assert usage is not None
    assert usage.user_id == user.id


def test_token_cannot_be_reused(user):
    from apps.accounts.autologin.views import issue_token

    _, plaintext = issue_token(user=user)
    client = Client()
    url = reverse("autologin", args=[plaintext])

    first = client.post(url)
    assert first.status_code == 302

    second = client.post(url)
    assert second.status_code == 302
    assert "autologin=used" in second.url


@pytest.mark.django_db
def test_unknown_token_returns_invalid():
    client = Client()
    url = reverse("autologin", args=["completely-bogus-token-zzz"])
    response = client.post(url)
    assert response.status_code == 302
    assert "autologin=invalid" in response.url


@pytest.mark.django_db
def test_expired_token_returns_expired(user, settings):
    from datetime import timedelta

    from apps.accounts.autologin.models import AutoLoginToken
    from apps.accounts.autologin.views import issue_token

    settings.AUTOLOGIN_TOKEN_TTL = 1
    _, plaintext = issue_token(user=user)
    AutoLoginToken.all_objects.filter(token_hash=_hash(plaintext)).update(
        expires_at=timezone.now() - timedelta(seconds=10),
    )

    client = Client()
    url = reverse("autologin", args=[plaintext])
    response = client.post(url)
    assert response.status_code == 302
    assert "autologin=expired" in response.url


def _hash(token: str) -> str:
    import hashlib
    return hashlib.sha256(token.encode("utf-8")).hexdigest()