# {{ project_name }} — environment variables template
# Copy to .env and edit. NEVER commit .env with real secrets.

# ---------------------------------------------------------------------------
# Django core
# ---------------------------------------------------------------------------
# Generate a real one with:
#   python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-change-in-production-must-be-at-least-50-chars-long-xxx
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_ENVIRONMENT=local
{% if database == 'postgresql' %}
# ---------------------------------------------------------------------------
# Database (PostgreSQL — production)
# ---------------------------------------------------------------------------
DB_NAME={{ project_slug }}
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432
{%- else %}
# ---------------------------------------------------------------------------
# Database (SQLite — development only)
# ---------------------------------------------------------------------------
# SQLite is configured automatically via DATABASES in local.py.
{%- endif %}
{% if admin %}
# ---------------------------------------------------------------------------
# Allauth (admin=unfold)
# ---------------------------------------------------------------------------
# mandatory | optional | none
ACCOUNT_EMAIL_VERIFICATION=mandatory
{%- endif %}
{% if include_jobs %}
# ---------------------------------------------------------------------------
# django-q2 (background jobs)
# ---------------------------------------------------------------------------
{%- if jobs_backend == 'redis' %}
REDIS_HOST=localhost
REDIS_PORT=6379
{%- else %}
# Broker ORM usa la DB existente — no requiere Redis.
{%- endif %}
{%- endif %}
{% if persists_sensitive_data %}
# ---------------------------------------------------------------------------
# Fernet encryption (encryption at rest)
# ---------------------------------------------------------------------------
# Required. Generate with:
#   python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
FERNET_ENCRYPTION_KEY=
{%- endif %}