"""GHL integration — OAuth2 + v2 API client + installation storage."""

from __future__ import annotations

from django.db import models

from apps.core.models.base import BaseModel
{% if persists_sensitive_data or 'module-secure-endpoints' in optional_modules or 'module-wompi' in optional_modules or 'module-ghl' in optional_modules or 'module-supabase' in optional_modules or 'module-autologin-tests360' in optional_modules %}
from apps.core.models.fields import EncryptedCharField
{%- endif %}
{% if include_multitenant and multitenant_isolation == 'logical' %}
from apps.tenants.mixins import TenantAwareModelMixin
from apps.tenants.models import Tenant
{%- endif %}


class GhlInstallation(BaseModel):
    """An authorised GHL sub-account connection (per tenant when multitenant)."""
{% if include_multitenant and multitenant_isolation == 'logical' %}

    tenant = models.ForeignKey(
        Tenant, on_delete=models.CASCADE, related_name="ghl_installations"
    )
{%- else %}
    name = models.CharField(max_length=200, default="default")
{%- endif %}
    location_id = models.CharField(max_length=128, unique=True)
    location_name = models.CharField(max_length=200, blank=True, default="")
    company_id = models.CharField(max_length=128, blank=True, default="")
{% if persists_sensitive_data or 'module-secure-endpoints' in optional_modules or 'module-wompi' in optional_modules or 'module-ghl' in optional_modules or 'module-supabase' in optional_modules or 'module-autologin-tests360' in optional_modules %}
    access_token = EncryptedCharField(max_length=2048)
    refresh_token = EncryptedCharField(max_length=2048)
{%- else %}
    # Fernet not active — tokens stored in plaintext. NOT recommended for
    # production. Activate Fernet or any Fernet-triggering module.
    access_token = models.CharField(max_length=2048)
    refresh_token = models.CharField(max_length=2048)
{%- endif %}
    scopes = models.TextField(blank=True, default="")
    expires_at = models.DateTimeField(null=True, blank=True)
    is_active = models.BooleanField(default=True)

    class Meta:
        verbose_name = "GHL installation"
        verbose_name_plural = "GHL installations"

    def __str__(self) -> str:
{% if include_multitenant and multitenant_isolation == 'logical' %}
        return f"GHL installation {self.location_id} (tenant={self.tenant_id})"
{%- else %}
        return f"GHL installation {self.location_id}"
{%- endif %}


class GhlWebhookEvent(BaseModel):
    """Append-only record of received GHL webhooks (for debugging)."""

    event_type = models.CharField(max_length=128, db_index=True)
    location_id = models.CharField(max_length=128, blank=True, default="", db_index=True)
    raw_payload = models.JSONField(default=dict, blank=True)

    class Meta:
        verbose_name = "GHL webhook event"
        verbose_name_plural = "GHL webhook events"
        ordering = ["-created_at"]

    def __str__(self) -> str:
        return f"{self.event_type} @ {self.created_at:%Y-%m-%dT%H:%M:%S}"