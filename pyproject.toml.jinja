[build-system]
requires = ["setuptools>=68", "wheel"]
build-backend = "setuptools.build_meta"

[tool.setuptools]
# packages list is built dynamically below — Copier Jinja resolves the conditional
# modules to determine which apps exist in the generated project. Keep this in sync
# with the PROJECT_APPS list in config/settings/base.py.jinja.
{% set _packages = ["apps", "config", "apps.core", "apps.core.models", "apps.core.middleware", "apps.core.utils", "apps.core.management", "apps.core.management.commands", "apps.core.views"] -%}
{%- if admin %}
{%- set _packages = _packages + ["apps.accounts", "apps.accounts.models", "apps.accounts.admin", "apps.accounts.adapters", "apps.accounts.migrations"] %}
{%- endif %}
{%- if 'module-autologin-tests360' in optional_modules and admin %}
{%- set _packages = _packages + ["apps.accounts.autologin", "apps.accounts.autologin.migrations"] %}
{%- endif %}
{%- if frontend %}
{%- set _packages = _packages + ["apps.web"] %}
{%- endif %}
{%- if include_multitenant or 'module-multitenant' in optional_modules %}
{%- set _packages = _packages + ["apps.tenants", "apps.tenants.migrations"] %}
{%- endif %}
{%- if 'module-wompi' in optional_modules %}
{%- set _packages = _packages + ["apps.payments", "apps.payments.wompi", "apps.payments.wompi.migrations"] %}
{%- endif %}
{%- if 'module-ghl' in optional_modules or 'module-supabase' in optional_modules %}
{%- set _packages = _packages + ["apps.integrations"] %}
{%- endif %}
{%- if 'module-ghl' in optional_modules %}
{%- set _packages = _packages + ["apps.integrations.ghl", "apps.integrations.ghl.migrations"] %}
{%- endif %}
{%- if 'module-supabase' in optional_modules %}
{%- set _packages = _packages + ["apps.integrations.supabase", "apps.integrations.supabase.migrations"] %}
{%- endif %}
{%- if 'module-realtime' in optional_modules %}
{%- set _packages = _packages + ["apps.realtime"] %}
{%- endif %}
{%- if api %}
{%- set _packages = _packages + ["apps.api"] %}
{%- endif %}
packages = {{ _packages | to_json }}

[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ project_name }}"
requires-python = ">={{ python_version }}"
dependencies = [
    "django>={{ django_version }},<7.0",
    "psycopg[binary]>=3.2,<4.0",
    "python-dotenv>=1.0,<2.0",
    "whitenoise>=6.9,<7.0",
    "gunicorn>=23.0,<24.0",
    "structlog>=25.0,<26.0",
    "django-filter>=25.1,<26.0",
{%- if persists_sensitive_data or 'module-secure-endpoints' in optional_modules or 'module-wompi' in optional_modules or 'module-ghl' in optional_modules or 'module-supabase' in optional_modules or 'module-autologin-tests360' in optional_modules %}
    # cryptography is required by EncryptedCharField (apps.core.models.fields).
    # Auto-installed when persists_sensitive_data=yes or any Fernet-triggering
    # module is selected.
    "cryptography>=42,<43.0",
{%- endif %}
{%- if include_jobs %}
    "django-q2>=1.7,<2.0",
{%- endif %}
{%- if api %}
    "django-ninja>=1.4,<2.0",
    "pydantic>=2.10,<3.0",
{%- endif %}
{%- if admin %}
    "django-allauth>=65.0,<66.0",
    "django-unfold>=0.4,<1.0",
{%- endif %}
{%- if frontend %}
    "django-cotton>=2.0,<3.0",
    "django-htmx>=1.19,<2.0",
    "django-vite>=3.0,<4.0",
{%- endif %}
{%- if include_multitenant and multitenant_isolation == 'schema' %}
    "django-tenants>=3.0,<4.0",
{%- endif %}
{%- if 'module-realtime' in optional_modules %}
    "channels>=4.1,<5.0",
    "channels-redis>=4.2,<5.0",
    "daphne>=4.1,<5.0",
{%- endif %}
{%- if 'module-django-guard' in optional_modules %}
    "django-guardian>=3.0,<4.0",
{%- endif %}
{%- if 'module-wompi' in optional_modules or 'module-ghl' in optional_modules or 'module-supabase' in optional_modules %}
    "httpx>=0.27,<1.0",
{%- endif %}
]

[dependency-groups]
dev = [
    "pytest>=8.0,<9.0",
    "pytest-django>=4.9,<5.0",
    "model-bakery>=1.20,<2.0",
    "ruff>=0.15,<1.0",
    "mypy>=1.15,<2.0",
    "django-stubs>=5.1,<6.0",
{%- if include_debug_toolbar %}
    "django-debug-toolbar>=4.4,<6.0",
{%- endif %}
{%- if 'module-realtime' in optional_modules %}
    "pytest-asyncio>=0.24,<1.0",
{%- endif %}
]

[tool.ruff]
line-length = 120
target-version = "py{{ python_version | replace('.', '') }}"

[tool.ruff.lint]
select = ["E", "F", "I", "B", "UP", "DJ", "SIM"]
ignore = ["D203", "D212", "D213", "D415", "E501"]

[tool.ruff.format]
quote-style = "double"
indent-style = "space"

[tool.mypy]
plugins = ["mypy_django_plugin.main"]
ignore_missing_imports = true
strict_optional = true
warn_unused_ignores = true
exclude = ["migrations/", "tests/"]

[tool.django-stubs]
django_settings_module = "{{ django_settings_module }}.test"