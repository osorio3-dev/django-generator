/* Server-rendered JS entry — imports Tailwind v4 CSS + HTMX + Alpine + Preline.
   Vite reads this file (see vite.config.ts) and outputs the manifest to static/dist/. */
import '../css/main.css';
import 'htmx.org';
import Alpine from 'alpinejs';
import collapse from '@alpinejs/collapse';
import 'preline';

window.Alpine = Alpine;
Alpine.plugin(collapse);
Alpine.start();

/* Re-initialize Preline after every HTMX swap so its dropdowns / modals / etc.
   bind correctly to the freshly inserted DOM nodes. Without this, Preline
   components inside HTMX responses appear dead. */
document.body.addEventListener('htmx:afterSwap', () => {
  if (window.HSStaticMethods && typeof window.HSStaticMethods.autoInit === 'function') {
    window.HSStaticMethods.autoInit();
  }
});
