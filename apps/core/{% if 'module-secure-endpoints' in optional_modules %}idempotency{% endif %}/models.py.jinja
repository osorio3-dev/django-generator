"""Idempotency cache model.

A row exists for each (tenant_id, key) tuple the middleware has replayed or
persisted. The model is intentionally simple: no FK to the originating
request, no payload body — only the digest and the cached response body.
"""

from __future__ import annotations

from django.db import models

from apps.core.models.base import BaseModel


class IdempotencyKey(BaseModel):
    """Cached response for an X-Idempotency-Key-protected request."""

    # tenant_id is optional because multitenant is opt-in. When the
    # multitenant module is active, the middleware passes tenant.id here.
    tenant_id = models.BigIntegerField(null=True, blank=True, db_index=True)
    key = models.CharField(max_length=255)
    payload_hash = models.CharField(max_length=64)  # SHA256 hex digest
    response_status = models.PositiveSmallIntegerField()
    response_content_type = models.CharField(max_length=128, blank=True, default="")
    response_body = models.TextField(blank=True, default="")

    class Meta:
        unique_together = [("tenant_id", "key")]
        indexes = [models.Index(fields=["created_at"])]
        verbose_name = "Idempotency key"
        verbose_name_plural = "Idempotency keys"

    def __str__(self) -> str:
        return f"IdempotencyKey({self.key[:24]}, tenant={self.tenant_id})"