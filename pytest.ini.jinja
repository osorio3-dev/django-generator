[pytest]
DJANGO_SETTINGS_MODULE = {{ django_settings_module }}.test
python_files = test_*.py *_test.py
testpaths = tests
addopts = -ra --strict-markers
# Registered always — only used by module-realtime tests, but pytest will
# refuse to collect unmarked async tests if this is missing.
markers =
    asyncio: pytest-asyncio marker for async WebSocket consumer tests (module-realtime).