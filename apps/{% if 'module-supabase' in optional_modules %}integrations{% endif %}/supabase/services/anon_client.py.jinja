"""Supabase anonymous REST client (anon key + RLS).

Use this client for any read or write that should be subject to Row-Level
Security policies. The anon key is the same one you'd ship to the SPA — it
has limited privileges by virtue of RLS rules in the database.
"""

from __future__ import annotations

from typing import Any

import httpx


class SupabaseAnonClient:
    """REST client scoped to the anon role + RLS.

    All requests go through PostgREST with the anon Authorization header.
    RLS policies in the database enforce the actual access control.
    """

    def __init__(self, project_url: str, anon_key: str, *, timeout: float = 15.0) -> None:
        if not project_url or not anon_key:
            raise ValueError("project_url and anon_key are required.")
        self.base_url = project_url.rstrip("/")
        self.anon_key = anon_key
        self._timeout = timeout

    def _headers(self, *, extra: dict | None = None) -> dict:
        return {
            "apikey": self.anon_key,
            "Authorization": f"Bearer {self.anon_key}",
            "Content-Type": "application/json",
            "Accept": "application/json",
            **(extra or {}),
        }

    def select(
        self,
        table: str,
        *,
        columns: str = "*",
        filters: dict[str, Any] | None = None,
        limit: int | None = None,
    ) -> list[dict]:
        """Read rows from a table. Filters are passed as query params."""
        params: dict[str, Any] = {"select": columns}
        if filters:
            for key, value in filters.items():
                # PostgREST syntax: column=eq.value
                params[key] = f"eq.{value}"
        if limit:
            params["limit"] = str(limit)
        url = f"{self.base_url}/rest/v1/{table}"
        r = httpx.get(url, params=params, headers=self._headers(), timeout=self._timeout)
        r.raise_for_status()
        return r.json()

    def insert(self, table: str, payload: dict | list[dict]) -> list[dict]:
        """Insert rows. Returns the inserted rows."""
        url = f"{self.base_url}/rest/v1/{table}"
        headers = self._headers(extra={"Prefer": "return=representation"})
        body = payload if isinstance(payload, list) else [payload]
        r = httpx.post(url, json=body, headers=headers, timeout=self._timeout)
        r.raise_for_status()
        return r.json()

    def update(self, table: str, payload: dict, *, filters: dict[str, Any]) -> list[dict]:
        """Update rows matching the filters."""
        params: dict[str, Any] = {}
        for key, value in filters.items():
            params[key] = f"eq.{value}"
        url = f"{self.base_url}/rest/v1/{table}"
        headers = self._headers(extra={"Prefer": "return=representation"})
        r = httpx.patch(url, params=params, json=payload, headers=headers, timeout=self._timeout)
        r.raise_for_status()
        return r.json()

    def delete(self, table: str, *, filters: dict[str, Any]) -> None:
        """Delete rows matching the filters."""
        params: dict[str, Any] = {}
        for key, value in filters.items():
            params[key] = f"eq.{value}"
        url = f"{self.base_url}/rest/v1/{table}"
        r = httpx.delete(url, params=params, headers=self._headers(), timeout=self._timeout)
        r.raise_for_status()