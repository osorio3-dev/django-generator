[build-system]
requires = ["setuptools>=68", "wheel"]
build-backend = "setuptools.build_meta"

[tool.setuptools]
packages = ["apps", "config", "apps.core", "apps.core.models", "apps.core.middleware", "apps.core.utils", "apps.core.management", "apps.core.management.commands", "apps.core.views"{% if admin %}, "apps.accounts", "apps.accounts.models", "apps.accounts.admin", "apps.accounts.adapters", "apps.accounts.migrations"{% endif %}]

[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ project_name }}"
requires-python = ">={{ python_version }}"
dependencies = [
    "django>={{ django_version }},<7.0",
    "psycopg[binary]>=3.2,<4.0",
    "python-dotenv>=1.0,<2.0",
    "whitenoise>=6.9,<7.0",
    "gunicorn>=23.0,<24.0",
    "structlog>=25.0,<26.0",
    "django-filter>=25.1,<26.0",
    "cryptography>=42,<43.0",
{%- if include_jobs %}
    "django-q2>=1.7,<2.0",
{%- endif %}
{%- if api %}
    "django-ninja>=1.4,<2.0",
    "pydantic>=2.10,<3.0",
{%- endif %}
{%- if admin %}
    "django-allauth>=65.0,<66.0",
    "django-unfold>=0.4,<1.0",
{%- endif %}
{%- if frontend %}
    "django-cotton>=2.0,<3.0",
    "django-htmx>=1.19,<2.0",
    "django-vite>=3.0,<4.0",
{%- endif %}
]

[dependency-groups]
dev = [
    "pytest>=8.0,<9.0",
    "pytest-django>=4.9,<5.0",
    "model-bakery>=1.20,<2.0",
    "ruff>=0.15,<1.0",
    "mypy>=1.15,<2.0",
    "django-stubs>=5.1,<6.0",
]

[tool.ruff]
line-length = 120
target-version = "py{{ python_version | replace('.', '') }}"

[tool.ruff.lint]
select = ["E", "F", "I", "B", "UP", "DJ", "SIM"]
ignore = ["D203", "D212", "D213", "D415", "E501"]

[tool.ruff.format]
quote-style = "double"
indent-style = "space"

[tool.mypy]
plugins = ["mypy_django_plugin.main"]
ignore_missing_imports = true
strict_optional = true
warn_unused_ignores = true
exclude = ["migrations/", "tests/"]

[tool.django-stubs]
django_settings_module = "{{ django_settings_module }}.test"