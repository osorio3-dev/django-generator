# ── HMAC verifier ──────────────────────────────────────────────────────


def test_hmac_sha256_verifier_accepts_correct_signature():
    from apps.core.webhooks.services.verifier import HMAC_SHA256Verifier
    import hashlib
    import hmac

    secret = "shhh-secret"
    payload = {
        "data": {"transaction": {"id": "TX-1", "status": "APPROVED"}},
        "signature": {
            "properties": ["data.transaction.id", "data.transaction.status"],
            "checksum": "",
        },
    }
    concatenated = "TX-1" + "APPROVED"
    payload["signature"]["checksum"] = hmac.new(
        secret.encode(), concatenated.encode(), hashlib.sha256
    ).hexdigest()
    assert HMAC_SHA256Verifier(secret).verify(payload) is True


def test_hmac_sha256_verifier_rejects_tampered_checksum():
    from apps.core.webhooks.services.verifier import HMAC_SHA256Verifier

    secret = "shhh-secret"
    payload = {
        "data": {"transaction": {"id": "TX-1", "status": "APPROVED"}},
        "signature": {
            "properties": ["data.transaction.id"],
            "checksum": "0" * 64,
        },
    }
    assert HMAC_SHA256Verifier(secret).verify(payload) is False


def test_hmac_sha256_verifier_rejects_missing_signature():
    from apps.core.webhooks.services.verifier import HMAC_SHA256Verifier

    assert HMAC_SHA256Verifier("x").verify({"data": {}}) is False


def test_raw_hmac_sha256_verifier_roundtrip():
    from apps.core.webhooks.services.verifier import RawHMACSHA256Verifier

    secret = "abc"
    body = b'{"event":"order.created"}'
    verifier = RawHMACSHA256Verifier(secret)
    sig = verifier.sign(body)
    assert verifier.verify(body, sig) is True
    assert verifier.verify(body, "deadbeef") is False


def test_raw_hmac_sha256_verifier_requires_secret():
    from apps.core.webhooks.services.verifier import RawHMACSHA256Verifier

    with pytest.raises(ValueError):
        RawHMACSHA256Verifier("")


# ── Signed tokens ──────────────────────────────────────────────────────


def test_signed_token_roundtrip(settings):
    from apps.core.webhooks.services.signed_token import issue, verify

    settings.SECRET_KEY = "x" * 60  # avoid placeholder guard
    token = issue({"user_id": 1, "action": "verify_email"}, ttl_seconds=60)
    payload = verify(token)
    assert payload == {"user_id": 1, "action": "verify_email"}


def test_signed_token_rejects_tampered_signature(settings):
    from apps.core.webhooks.services.signed_token import issue, verify

    settings.SECRET_KEY = "x" * 60
    token = issue({"a": 1}, ttl_seconds=60)
    body, sig = token.rsplit(".", 1)
    flipped_sig = ("0" if sig[-1] != "0" else "1") + sig[1:]
    assert verify(f"{body}.{flipped_sig}") is None


def test_signed_token_rejects_expired(settings):
    from apps.core.webhooks.services import signed_token

    settings.SECRET_KEY = "x" * 60
    with patch_time(signed_token, 0):
        token = signed_token.issue({"a": 1}, ttl_seconds=10)
    with patch_time(signed_token, 1_000_000):
        assert signed_token.verify(token) is None


def test_signed_token_rejects_placeholder_secret(settings):
    from apps.core.webhooks.services.signed_token import issue

    settings.SECRET_KEY = "your-secret-key-change-in-production-must-be-at-least-50-chars-long-xxx"
    with pytest.raises(ValueError):
        issue({"a": 1})


def patch_time(module, value: float):
    """Context manager that mocks module.time.time() to return value."""
    from contextlib import contextmanager
    from unittest.mock import patch

    @contextmanager
    def _ctx():
        with patch.object(module.time, "time", return_value=value):
            yield

    return _ctx()


