{% if admin -%}
"""UNFOLD admin settings — isolated from base.py.

This module is imported by ``base.py`` only when ``admin=true``. It centralises
the Unfold configuration (branding, sidebar navigation, tabs, colors, command
palette) so the rest of the settings stays focused on infrastructure.

Spanish labels are intentional — the project owner works in Spanish.
"""
{% endif %}
{% if admin %}
import os

from django.utils.translation import gettext_lazy as _


def _parse_bool_env(key: str, default: str = "false") -> bool:
    """Parse a boolean env var case-insensitively."""
    raw = os.environ.get(key, default)
    return raw.lower() in ("true", "1", "yes")


def _environment(request):
    """Return the environment badge shown in the admin header.

    Reads DEBUG at runtime (not at module import) so toggling the env var
    doesn't require a settings reload.
    """
    if _parse_bool_env("DEBUG"):
        return "local"
    return os.environ.get("DJANGO_ENVIRONMENT", "production")


def _disable_command_in_production():
    """Hide dangerous commands from the Cmd+K palette when not in DEBUG."""
    if _parse_bool_env("DEBUG"):
        return []
    return ["makemessages", "compilemessages", "makemigrations"]


