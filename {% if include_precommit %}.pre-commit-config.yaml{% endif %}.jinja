# pre-commit config for {{ project_name }}.
#
# Activated only when module-precommit is selected. Wires:
# - ruff (lint + import sort)
# - ruff-format (replaces Black)
# - standard hygiene hooks (trailing-whitespace, end-of-file, yaml/toml/json checks)

# Pin the pre-commit version to keep behaviour stable across machines.
minimum_pre_commit_version: "4.0.0"

repos:
  - repo: https://github.com/astral-sh/ruff-pre-commit
    rev: v0.8.6
    hooks:
      - id: ruff
        args: ["--fix", "--exit-non-zero-on-fix"]
        types_or: [python, pyi]
      - id: ruff-format
        types_or: [python, pyi]

  - repo: https://github.com/pre-commit/pre-commit-hooks
    rev: v5.0.0
    hooks:
      - id: trailing-whitespace
        exclude: \.md$
      - id: end-of-file-fixer
        exclude: \.md$
      - id: check-merge-conflict
      - id: check-added-large-files
        args: ["--maxkb=500"]
      - id: check-toml
      - id: check-yaml
        exclude: ^docker-compose.*\.yml$
      - id: check-json
      - id: mixed-line-ending
        args: ["--fix=lf"]

  - repo: https://github.com/adrienverge/yamllint
    rev: v1.35.1
    hooks:
      - id: yamllint
        args: ["--strict"]
        files: \.(yml|yaml)$
        exclude: ^docker-compose.*\.yml$