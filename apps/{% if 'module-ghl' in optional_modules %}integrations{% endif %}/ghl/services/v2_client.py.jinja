"""GHL v2 API client.

OAuth2 client_credentials + Bearer-authenticated requests. Includes a
simple in-memory token cache and ``Retry-After``-aware retry on 429.

Anti-pattern avoided (inpacto-pagos-ghl audit): never use the global agency
API key for tenant-scoped queries — always go through the per-installation
access_token which is scoped to a single ``location_id``.
"""

from __future__ import annotations

import threading
import time
from typing import Any
from urllib.parse import urlencode

import httpx
from django.conf import settings


class GhlApiError(Exception):
    """Raised when GHL returns a non-success status."""


class GhlV2Client:
    """OAuth2-aware client for the GoHighLevel v2 API."""

    BASE_URL = "https://services.leadconnectorhq.com"
    OAUTH_URL = "https://services.leadconnectorhq.com/oauth/token"

    def __init__(
        self,
        installation,  # GhlInstallation instance
        *,
        timeout: float = 15.0,
        max_retries: int = 3,
    ) -> None:
        self.installation = installation
        self._timeout = timeout
        self._max_retries = max_retries
        self._token_lock = threading.Lock()

    # ── OAuth2 ────────────────────────────────────────────────────────────

    def exchange_code_for_token(self, code: str, redirect_uri: str) -> dict:
        """Trade an authorisation code for an access_token + refresh_token."""
        data = {
            "grant_type": "authorization_code",
            "code": code,
            "client_id": settings.GHL_CLIENT_ID,
            "client_secret": settings.GHL_CLIENT_SECRET,
            "redirect_uri": redirect_uri,
        }
        r = httpx.post(self.OAUTH_URL, data=data, timeout=self._timeout)
        r.raise_for_status()
        return r.json()

    def refresh_access_token(self) -> None:
        """Refresh the installation's access_token via its refresh_token."""
        if not self.installation.refresh_token:
            raise GhlApiError("No refresh_token available.")

        data = {
            "grant_type": "refresh_token",
            "refresh_token": self.installation.refresh_token,
            "client_id": settings.GHL_CLIENT_ID,
            "client_secret": settings.GHL_CLIENT_SECRET,
        }
        with self._token_lock:
            r = httpx.post(self.OAUTH_URL, data=data, timeout=self._timeout)
            r.raise_for_status()
            body = r.json()

            self.installation.access_token = body["access_token"]
            if "refresh_token" in body:
                self.installation.refresh_token = body["refresh_token"]
            self.installation.expires_at = None  # GHL doesn't always return this
            self.installation.save(update_fields=["access_token", "refresh_token", "expires_at", "updated_at"])

    # ── API calls ────────────────────────────────────────────────────────

    def _auth_headers(self) -> dict:
        return {
            "Authorization": f"Bearer {self.installation.access_token}",
            "Version": "2021-07-28",
            "Accept": "application/json",
        }

    def request(
        self,
        method: str,
        path: str,
        *,
        params: dict | None = None,
        json_body: dict | None = None,
    ) -> dict:
        """Authenticated request with 429-aware retry."""
        url = f"{self.BASE_URL}{path}"
        headers = self._auth_headers()

        for attempt in range(self._max_retries):
            r = httpx.request(
                method,
                url,
                params=params,
                json=json_body,
                headers=headers,
                timeout=self._timeout,
            )
            if r.status_code == 429 and attempt < self._max_retries - 1:
                # Honour Retry-After when present, else exponential backoff.
                retry_after = int(r.headers.get("Retry-After", "0") or 0)
                delay = retry_after if retry_after > 0 else (2 ** attempt)
                time.sleep(delay)
                continue
            if r.status_code == 401 and self.installation.refresh_token:
                # Token expired → refresh and retry once.
                self.refresh_access_token()
                headers = self._auth_headers()
                r = httpx.request(method, url, params=params, json=json_body, headers=headers, timeout=self._timeout)
            if not r.is_success:
                raise GhlApiError(f"GHL {method} {path} → {r.status_code}: {r.text[:200]}")
            return r.json() if r.content else {}

        raise GhlApiError(f"GHL {method} {path} exhausted retries.")

    # ── Convenience wrappers ─────────────────────────────────────────────

    def get_contacts(self, *, limit: int = 100, query: str | None = None) -> dict:
        params: dict[str, Any] = {"locationId": self.installation.location_id, "limit": limit}
        if query:
            params["query"] = query
        return self.request("GET", "/contacts/", params=params)

    def get_contact(self, contact_id: str) -> dict:
        return self.request("GET", f"/contacts/{contact_id}")

    def create_contact(self, payload: dict) -> dict:
        payload = {**payload, "locationId": self.installation.location_id}
        return self.request("POST", "/contacts/", json_body=payload)

    def update_contact(self, contact_id: str, payload: dict) -> dict:
        return self.request("PUT", f"/contacts/{contact_id}", json_body=payload)

    def get_opportunities(self, *, pipeline_id: str | None = None, limit: int = 100) -> dict:
        params = {"locationId": self.installation.location_id, "limit": limit}
        if pipeline_id:
            params["pipelineId"] = pipeline_id
        return self.request("GET", "/opportunities/search", params=params)

    def build_authorize_url(self, redirect_uri: str, scopes: str | None = None) -> str:
        """Build the OAuth2 authorisation URL the user clicks on."""
        scopes = scopes or settings.GHL_OAUTH_SCOPES
        params = {
            "client_id": settings.GHL_CLIENT_ID,
            "redirect_uri": redirect_uri,
            "response_type": "code",
            "scope": scopes,
            "state": self.installation.location_id,
        }
        return f"{self.BASE_URL}/oauth/authorize?{urlencode(params)}"