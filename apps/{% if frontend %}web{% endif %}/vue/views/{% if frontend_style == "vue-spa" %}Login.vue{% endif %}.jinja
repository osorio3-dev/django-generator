<template>
  <section class="max-w-md mx-auto py-12 px-4">
    <h1 class="text-2xl font-semibold text-gray-800 dark:text-white mb-6">
      Sign in to {{ projectName }}
    </h1>
    <form
      method="post"
      action="{% raw %}/accounts/login/{% endraw %}"
      class="space-y-4"
    >
      <input type="hidden" name="csrfmiddlewaretoken" :value="csrfToken" />
      <label class="block">
        <span class="text-sm text-gray-700 dark:text-neutral-300">Email</span>
        <input
          type="email"
          name="email"
          required
          autocomplete="email"
          class="mt-1 block w-full rounded-lg border-gray-200 shadow-sm dark:bg-neutral-800 dark:border-neutral-700"
        />
      </label>
      <label class="block">
        <span class="text-sm text-gray-700 dark:text-neutral-300">Password</span>
        <input
          type="password"
          name="password"
          required
          autocomplete="current-password"
          class="mt-1 block w-full rounded-lg border-gray-200 shadow-sm dark:bg-neutral-800 dark:border-neutral-700"
        />
      </label>
      <button
        type="submit"
        class="w-full py-2 px-4 rounded-lg bg-blue-600 text-white hover:bg-blue-700"
      >
        Sign in
      </button>
    </form>
  </section>
</template>

<script setup>
{% if frontend_style == 'vue-spa' %}
// Auth posts to Django's allauth endpoint. The CSRF token is read from the
// cookie set by django.middleware.csrf. After successful auth, allauth
// redirects to LOGIN_REDIRECT_URL ('/'). All subsequent API calls carry the
// session cookie automatically.
import { ref, onMounted } from 'vue';

const projectName = {{ project_name | tojson }};

function readCsrfCookie() {
  const match = document.cookie.match(/csrftoken=([^;]+)/);
  return match ? match[1] : '';
}

const csrfToken = ref('');

onMounted(() => {
  csrfToken.value = readCsrfCookie();
});
{% endif %}
</script>