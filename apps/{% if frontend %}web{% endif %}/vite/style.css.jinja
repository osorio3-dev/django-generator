{% if frontend and frontend_style == 'vue-spa' %}
/* Tailwind v4 entry — CSS-first config (no tailwind.config.js).
   Imported from this entry by way of vite.config alias resolution. */
@import "tailwindcss";
@import "preline/dist/preline.css";

@theme {
  --color-primary-50: #eff6ff;
  --color-primary-500: #3b82f6;
  --color-primary-600: #2563eb;
  --color-primary-700: #1d4ed8;
}
{% else %}
/* server-rendered projects use static/css/main.css instead of this file.
   Stub kept to make the directory structure uniform across styles. */
{% endif %}
