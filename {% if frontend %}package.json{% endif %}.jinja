{
  "name": "{{ project_slug }}",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  {% if package_manager == 'bun' -%}
  "packageManager": "bun@1.3.14",
  {%- else -%}
  "packageManager": "npm@10.5.0",
  {%- endif %}
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
    {% if frontend_style == 'server-rendered' -%}
    ,
    "type-check": "tsc --noEmit"
    {%- endif %}
  },
  "dependencies": {
    "preline": "^2.6.0"
    {% if frontend_style == 'server-rendered' -%}
    ,
    "htmx.org": "^2.0.4",
    "alpinejs": "^3.14.0",
    "@alpinejs/collapse": "^3.14.0"
    {%- endif %}
    {% if frontend_style == 'vue-spa' -%}
    ,
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
    {%- endif %}
  },
  "devDependencies": {
    "vite": "^6.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "tailwindcss": "^4.0.0"
    {% if frontend_style == 'server-rendered' -%}
    ,
    "typescript": "^5.6.0"
    {%- endif %}
    {% if frontend_style == 'vue-spa' -%}
    ,
    "@vitejs/plugin-vue": "^5.2.0",
    "typescript": "^5.6.0",
    "vue-tsc": "^2.1.0"
    {%- endif %}
  }
}
