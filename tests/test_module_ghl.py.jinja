"""Tests for module-ghl.

Asserts:
- GhlV2Client builds the correct authorization URL with required params.
- GhlV2Client returns 429-aware retry behaviour (Retry-After honoured).
- GhlV2Client auto-refreshes on 401 when refresh_token is available.
- GhlInstallation model has location_id unique and stores tokens encrypted
  when Fernet is active.

Skipped when module-ghl is not active.
"""

from unittest.mock import MagicMock, patch

import pytest

GHL_ACTIVE = {% if 'module-ghl' in optional_modules %}True{% else %}False{% endif %}


pytestmark = pytest.mark.skipif(
    not GHL_ACTIVE,
    reason="module-ghl not active in this project",
)


def test_ghl_build_authorize_url(settings):
    from apps.integrations.ghl.services.v2_client import GhlV2Client

    settings.GHL_CLIENT_ID = "client-xyz"
    settings.GHL_OAUTH_SCOPES = "contacts.read contacts.write"
    installation = MagicMock()
    installation.location_id = "loc_abc"
    client = GhlV2Client(installation)

    url = client.build_authorize_url(redirect_uri="https://app.example.com/callback")
    assert "client_id=client-xyz" in url
    assert "response_type=code" in url
    assert "scope=contacts.read+contacts.write" in url or "scope=contacts.read%20contacts.write" in url
    assert "state=loc_abc" in url


def test_ghl_refreshes_on_401(settings):
    from apps.integrations.ghl.services.v2_client import GhlV2Client

    settings.GHL_CLIENT_ID = "client-xyz"
    settings.GHL_CLIENT_SECRET = "secret-xyz"
    installation = MagicMock()
    installation.location_id = "loc_abc"
    installation.access_token = "old-token"
    installation.refresh_token = "refresh-token"
    installation.save = MagicMock()

    client = GhlV2Client(installation)

    with patch("apps.integrations.ghl.services.v2_client.httpx.request") as mock_request:
        mock_request.side_effect = [
            MagicMock(status_code=401, is_success=False),
            MagicMock(status_code=200, is_success=True, json=lambda: {"data": {"ok": True}}, content=b'{"data":{"ok":true}}'),
        ]
        with patch.object(client, "refresh_access_token") as mock_refresh:
            data = client.request("GET", "/contacts/")

    assert data == {"data": {"ok": True}}
    mock_refresh.assert_called_once()


