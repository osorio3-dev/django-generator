@pytest.fixture
def tenant(db):
    from apps.tenants.models import Tenant
    return Tenant.all_objects.create(
        name="Acme",
        slug="acme",
        location_id="loc-acme",
        is_active=True,
    )


def test_tenant_model_str(tenant):
    assert str(tenant) == "Acme (acme)"


def test_tenant_aware_mixin_filters_by_current_tenant(tenant):
    """When current_tenant is set, the default manager filters by it."""
    from apps.tenants.context import set_current_tenant, clear_current_tenant
    from apps.tenants.models import Site

    Site.all_objects.create(tenant=tenant, domain="acme.example.com")
    Site.all_objects.create(tenant=tenant, domain="www.acme.example.com")

    set_current_tenant(tenant)
    try:
        qs = Site.objects.all()
        assert qs.count() == 2
        assert all(s.tenant_id == tenant.id for s in qs)
    finally:
        clear_current_tenant()


def test_tenant_aware_mixin_all_objects_bypasses_filter(tenant):
    """all_objects sees all rows regardless of the thread-local."""
    from apps.tenants.context import set_current_tenant, clear_current_tenant
    from apps.tenants.models import Site

    Site.all_objects.create(tenant=tenant, domain="acme.example.com")

    set_current_tenant(None)
    try:
        assert Site.objects.count() == 0
        assert Site.all_objects.count() == 1
    finally:
        clear_current_tenant()


@pytest.mark.django_db
def test_middleware_resolves_tenant_by_location_id_header(tenant):
    from apps.tenants.middleware import TenantMiddleware
    from django.http import HttpResponse

    rf = RequestFactory()

    def view(request):
        return HttpResponse(f"tenant={request.tenant.id if request.tenant else 'none'}")

    middleware = TenantMiddleware(view)
    req = rf.get("/anything/")
    req.headers = {"X-Location-ID": "loc-acme"}
    response = middleware(req)
    assert b"tenant=" in response.content


@pytest.mark.django_db
def test_middleware_404s_when_tenant_aware_path_unknown(tenant):
    from apps.tenants.middleware import TenantMiddleware
    from django.http import HttpResponse

    rf = RequestFactory()
    middleware = TenantMiddleware(lambda r: HttpResponse("ok"))

    req = rf.get("/api/anything/")
    req.headers = {"X-Location-ID": "loc-does-not-exist"}
    response = middleware(req)
    assert response.status_code == 404


@pytest.mark.django_db
def test_middleware_allows_paths_outside_tenant_aware_prefixes(tenant):
    """Outside /api/, /webhooks/, /integrations/ the tenant may be None."""
    from apps.tenants.middleware import TenantMiddleware
    from django.http import HttpResponse

    rf = RequestFactory()
    middleware = TenantMiddleware(lambda r: HttpResponse("ok"))

    req = rf.get("/health/")
    req.headers = {"X-Location-ID": "loc-does-not-exist"}
    response = middleware(req)
    assert response.status_code == 200
    assert response.content == b"ok"
