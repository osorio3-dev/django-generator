"""AutoLogin models — token issuance and audit trail."""

from __future__ import annotations

from django.conf import settings
from django.db import models

from apps.core.models.base import BaseModel


class AutoLoginToken(BaseModel):
    """A single-use magic-link token.

    The token itself is stored as a SHA256 digest, not the plaintext. The
    plaintext is the URL fragment; we look up by hash on redemption.
    """

    user = models.ForeignKey(
        settings.AUTH_USER_MODEL,
        on_delete=models.CASCADE,
        related_name="autologin_tokens",
    )
    token_hash = models.CharField(max_length=64, unique=True, db_index=True)
    expires_at = models.DateTimeField()
    used_at = models.DateTimeField(null=True, blank=True)
    redirect_to = models.CharField(max_length=512, blank=True, default="/")

    class Meta:
        verbose_name = "AutoLogin token"
        verbose_name_plural = "AutoLogin tokens"
        indexes = [models.Index(fields=["expires_at"])]

    def __str__(self) -> str:
        return f"AutoLoginToken(user={self.user_id}, used={'yes' if self.used_at else 'no'})"

    @property
    def is_used(self) -> bool:
        return self.used_at is not None

    @property
    def is_expired(self) -> bool:
        from django.utils import timezone

        return timezone.now() >= self.expires_at

    def mark_used(self) -> None:
        """Atomic single-use marker."""
        from django.utils import timezone

        self.used_at = timezone.now()
        self.save(update_fields=["used_at", "updated_at"])


class AutoLoginUsage(BaseModel):
    """Append-only audit row for every autologin attempt (success or failure)."""

    user_id = models.BigIntegerField(null=True, blank=True, db_index=True)
    token_hash = models.CharField(max_length=64, blank=True, default="")
    outcome = models.CharField(max_length=16)  # success | invalid | expired | used
    ip = models.GenericIPAddressField(null=True, blank=True)
    user_agent = models.CharField(max_length=255, blank=True, default="")

    class Meta:
        verbose_name = "AutoLogin usage"
        verbose_name_plural = "AutoLogin usage"
        ordering = ["-created_at"]

    def __str__(self) -> str:
        return f"{self.outcome} @ {self.created_at:%Y-%m-%dT%H:%M:%S}"