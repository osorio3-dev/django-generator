def test_websocket_urlpatterns_exists():
    from apps.realtime.routing import websocket_urlpatterns

    assert isinstance(websocket_urlpatterns, list)
    assert len(websocket_urlpatterns) >= 1


@pytest.mark.asyncio
async def test_base_consumer_handles_ping():
    """Echo test: send ping, expect 'pong' back."""
    from apps.realtime.consumers import BaseConsumer

    consumer = BaseConsumer()
    # Stub the channel layer.
    sent: list[dict] = []

    async def fake_send_json(content):
        sent.append(content)

    consumer.send_json = fake_send_json  # type: ignore[assignment]
    await consumer.receive_json({"action": "ping", "payload": {"x": 1}, "request_id": "r1"})
    assert sent == [{"action": "ping", "result": {"pong": True, "echo": {"x": 1}}, "request_id": "r1"}]


@pytest.mark.asyncio
async def test_base_consumer_unknown_action_returns_error():
    from apps.realtime.consumers import BaseConsumer

    consumer = BaseConsumer()
    sent: list[dict] = []

    async def fake_send_json(content):
        sent.append(content)

    consumer.send_json = fake_send_json  # type: ignore[assignment]
    await consumer.receive_json({"action": "explode", "payload": {}, "request_id": "r2"})
    assert sent and "error" in sent[0]
    assert "explode" in sent[0]["error"]