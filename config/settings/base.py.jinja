# ---------------------------------------------------------------------------
# Fernet (encryption at rest)
# ---------------------------------------------------------------------------
# Fernet is conditional on `persists_sensitive_data=yes` (or modules that
# persist secrets/PII). cryptography is in the base dependencies for this reason.
_fernet_key = os.environ.get("FERNET_ENCRYPTION_KEY")
if not _fernet_key:
    raise ImproperlyConfigured(
        "FERNET_ENCRYPTION_KEY is required when persists_sensitive_data=true. "
        "Generate one with: "
        "python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'"
    )
FERNET_ENCRYPTION_KEY = _fernet_key
{%- endif %}
