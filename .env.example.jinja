# {{ project_name }} — environment variables template
# Copy to .env and edit. NEVER commit .env with real secrets.

# ---------------------------------------------------------------------------
# Django core
# ---------------------------------------------------------------------------
# Generate a real one with:
#   python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-change-in-production-must-be-at-least-50-chars-long-xxx
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_ENVIRONMENT=local
{% if database == 'postgresql' %}
# ---------------------------------------------------------------------------
# Database (PostgreSQL — production)
# ---------------------------------------------------------------------------
DB_NAME={{ project_slug }}
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432
{%- else %}
# ---------------------------------------------------------------------------
# Database (SQLite — development only)
# ---------------------------------------------------------------------------
# SQLite is configured automatically via DATABASES in local.py.
{%- endif %}
{% if admin %}
# ---------------------------------------------------------------------------
# Allauth (admin=unfold)
# ---------------------------------------------------------------------------
# mandatory | optional | none
ACCOUNT_EMAIL_VERIFICATION=mandatory
{%- endif %}
{% if include_jobs %}
# ---------------------------------------------------------------------------
# django-q2 (background jobs)
# ---------------------------------------------------------------------------
{%- if jobs_backend == 'redis' %}
REDIS_HOST=localhost
REDIS_PORT=6379
{%- else %}
# Broker ORM usa la DB existente — no requiere Redis.
{%- endif %}
{%- endif %}
{% if persists_sensitive_data or 'module-secure-endpoints' in optional_modules or 'module-wompi' in optional_modules or 'module-ghl' in optional_modules or 'module-supabase' in optional_modules or 'module-autologin-tests360' in optional_modules %}
# ---------------------------------------------------------------------------
# Fernet encryption (encryption at rest)
# ---------------------------------------------------------------------------
# Required. Activated by persists_sensitive_data=yes OR any Fernet-triggering
# module (secure-endpoints, wompi, ghl, supabase, autologin-tests360).
# Generate with:
#   python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
FERNET_ENCRYPTION_KEY=
{%- endif %}
{% if 'module-wompi' in optional_modules %}
# ---------------------------------------------------------------------------
# Wompi (payments)
# ---------------------------------------------------------------------------
# Per-region public/private keys from https://comercios.wompi.co
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
# Webhook events secret (mandatory for production webhook signature verification).
WOMPI_EVENT_SECRET=
# Integrity secret for transaction signing (Colombia region).
WOMPI_INTEGRITY_SECRET=
WOMPI_REGION=CO
WOMPI_ENVIRONMENT=SANDBOX
{%- endif %}
{% if 'module-ghl' in optional_modules %}
# ---------------------------------------------------------------------------
# GoHighLevel (OAuth2)
# ---------------------------------------------------------------------------
# Get credentials from https://marketplace.gohighlevel.com
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_REDIRECT_URI=http://localhost:8000/integrations/ghl/callback/
GHL_OAUTH_SCOPES=locations.read locations.write contacts.read contacts.write
{%- endif %}
{% if 'module-supabase' in optional_modules %}
# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
# anon key is safe to expose to clients (RLS scoped). service_role is
# BACKEND-ONLY — never serve to a browser.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
{%- endif %}
{% if 'module-autologin-tests360' in optional_modules %}
# ---------------------------------------------------------------------------
# AutoLogin (tests-360 pattern)
# ---------------------------------------------------------------------------
# Seconds until magic-link token expires.
AUTOLOGIN_TOKEN_TTL=3600
{%- endif %}
{% if 'module-realtime' in optional_modules %}
# ---------------------------------------------------------------------------
# Channels (Redis backend)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
{%- endif %}