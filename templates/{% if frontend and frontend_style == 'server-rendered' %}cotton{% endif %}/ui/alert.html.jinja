<c-vars variant="info" title="" class="" />
{% if variant == 'success' %}
  {% set alert_classes = "bg-green-50 border border-green-200 text-green-800 dark:bg-green-800/30 dark:border-green-800 dark:text-green-400" %}
  {% set icon_path = "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" %}
{% elif variant == 'warning' %}
  {% set alert_classes = "bg-yellow-50 border border-yellow-200 text-yellow-800 dark:bg-yellow-800/30 dark:border-yellow-800 dark:text-yellow-400" %}
  {% set icon_path = "M12 9v2m0 4h.01M5.07 19h13.86c1.54 0 2.5-1.67 1.73-3L13.73 4a2 2 0 00-3.46 0L3.34 16c-.77 1.33.19 3 1.73 3z" %}
{% elif variant == 'error' %}
  {% set alert_classes = "bg-red-50 border border-red-200 text-red-800 dark:bg-red-800/30 dark:border-red-800 dark:text-red-400" %}
  {% set icon_path = "M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" %}
{% else %}
  {% set alert_classes = "bg-blue-50 border border-blue-200 text-blue-800 dark:bg-blue-800/30 dark:border-blue-800 dark:text-blue-400" %}
  {% set icon_path = "M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" %}
{% endif %}
<div class="{{ alert_classes }} rounded-xl p-4 {{ class|default('') }}" role="alert">
  <div class="flex">
    <svg class="shrink-0 w-5 h-5 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="{{ icon_path }}"/></svg>
    <div class="ms-3">
      {% if title %}
      <h3 class="text-sm font-semibold">{{ title }}</h3>
      {% endif %}
      <div class="text-sm {% if title %}mt-1{% endif %}">
        {{ slot }}
      </div>
    </div>
  </div>
</div>
