"""Root URL configuration."""

from django.urls import include, path  # noqa: F401

from apps.core.views.health import health_check

urlpatterns = [
    path("health/", health_check, name="health-check"),
]
{% if admin %}
# admin=unfold
from django.contrib import admin  # noqa: E402
from unfold.sites import UnfoldAdminSite  # noqa: E402

# Monkey-patch the default admin site to use Unfold's site class. This must
# run before admin.site.urls is built (or any ModelAdmin is registered) so
# Unfold takes over the rendering without re-registering every admin.
admin.site.__class__ = UnfoldAdminSite  # noqa: E402

from allauth.account.decorators import secure_admin_login  # noqa: E402

admin.site.login = secure_admin_login(admin.site.login)  # noqa: E402

urlpatterns += [
    path("admin/", admin.site.urls),
    path("accounts/", include("apps.accounts.urls")),  # noqa: F405
    path("accounts/", include("allauth.urls")),
]
{%- if 'module-autologin-tests360' in optional_modules %}
# module-autologin-tests360: POST-only token redemption plus a CSRF-protected
# confirmation page for zero-click UX. See autologin/views.py.
urlpatterns += [
    path("accounts/", include("apps.accounts.autologin.urls")),
]
{%- endif %}
{%- endif %}
{% if api %}
# api=django-ninja
from apps.api.router import api  # noqa: E402

urlpatterns += [
    path("api/", api.urls),
]
{%- endif %}
{% if frontend and frontend_style == 'vue-spa' %}
# vue-spa: SPA catch-all MUST come BEFORE apps.web.urls so it intercepts
# client-side routes (/, /dashboard/). Django-side endpoints (admin/, api/,
# accounts/, health/) are excluded by the regex and fall through to the
# configured routers. URLs ending in a dot (static assets with extensions)
# also fall through so WhiteNoise can serve them.
from django.urls import re_path  # noqa: E402
from django.views.generic import TemplateView  # noqa: E402

urlpatterns += [
    re_path(
        r"^(?!api/|admin/|accounts/|static/|health/|.*\.).*$",
        TemplateView.as_view(template_name="vue_spa.html"),
        name="vue_spa_catchall",
    ),
]
{%- endif %}
{% if frontend %}
# frontend enabled — mount the web app at the project root.
# The reverse lookup namespace is "web" (reverse("web:landing") etc.).
# For vue-spa, only `web:health_frontend` (under /health/) survives because
# the SPA catch-all above already claimed "/" and "/dashboard/".
urlpatterns += [
    path("", include("apps.web.urls")),
    # --- end generator-managed url includes ---
]
{% endif %}
{% set _debug_toolbar = include_debug_toolbar or 'module-debug-toolbar' in optional_modules %}
{% if _debug_toolbar %}
# django-debug-toolbar: OBLIGATORIO si el módulo está activo. El middleware
# inyecta HTML con reverse('djdt:render_panel') y reverse('djdt:history_sidebar')
# en cada respuesta HTML; sin este include, reverse() lanza NoReverseMatch
# en cualquier TemplateView (incluido "/" si devuelve HTML).
urlpatterns += [
    path("__debug__/", include("debug_toolbar.urls")),
]
{% endif %}
