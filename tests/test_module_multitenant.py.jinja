"""Tests for module-multitenant.

Asserts:
- Tenant + Site models exist and are registered.
- TenantAwareModelMixin auto-filters by current_tenant.
- TenantMiddleware resolves tenant by X-Location-ID header.
- TenantMiddleware enforces auth match (returns 403 on mismatch).
- TenantMiddleware 404s on tenant-aware paths when header is unknown.

Skipped when module-multitenant is not active.
"""

import pytest
from django.test import RequestFactory

