@pytest.fixture
def idempotency_middleware_cls():
    """Late-import the middleware so the skipif can short-circuit collection."""
    from apps.core.idempotency.middleware import IdempotencyMiddleware

    return IdempotencyMiddleware


@pytest.fixture
def idempotency_model_cls():
    from apps.core.idempotency.models import IdempotencyKey

    return IdempotencyKey


def test_idempotency_replays_cached_response(idem_factory, idempotency_middleware_cls):
    rf, view = idem_factory
    middleware = idempotency_middleware_cls(view)

    payload = b'{"a": 1}'
    req1 = rf.post("/api/test/", data=payload, content_type="application/json")
    req1.headers = {"X-Idempotency-Key": "abc-123"}
    resp1 = middleware(req1)
    assert resp1.status_code == 201

    req2 = rf.post("/api/test/", data=payload, content_type="application/json")
    req2.headers = {"X-Idempotency-Key": "abc-123"}
    resp2 = middleware(req2)
    assert resp2.status_code == 201
    assert resp2["X-Idempotent-Replay"] == "true"


def test_idempotency_returns_409_on_payload_mismatch(idem_factory, idempotency_middleware_cls):
    rf, view = idem_factory
    middleware = idempotency_middleware_cls(view)

    req1 = rf.post("/api/test/", data=b'{"a": 1}', content_type="application/json")
    req1.headers = {"X-Idempotency-Key": "abc-123"}
    middleware(req1)

    req2 = rf.post("/api/test/", data=b'{"a": 2}', content_type="application/json")
    req2.headers = {"X-Idempotency-Key": "abc-123"}
    resp2 = middleware(req2)
    assert resp2.status_code == 409


def test_idempotency_passes_through_without_key(idem_factory, idempotency_middleware_cls):
    rf, view = idem_factory
    middleware = idempotency_middleware_cls(view)

    req = rf.post("/api/test/", data=b'{"a": 1}', content_type="application/json")
    resp = middleware(req)
    assert resp.status_code == 201
    assert "X-Idempotent-Replay" not in resp


def test_idempotency_persists_row(idem_factory, idempotency_middleware_cls, idempotency_model_cls):
    rf, view = idem_factory
    middleware = idempotency_middleware_cls(view)

    req = rf.post("/api/test/", data=b'{"a": 1}', content_type="application/json")
    req.headers = {"X-Idempotency-Key": "persist-test"}
    middleware(req)

    assert idempotency_model_cls.objects.filter(key="persist-test").exists()